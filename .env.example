# PDF Extractext - Environment Variables
# Copia este archivo a .env y configura los valores

# ============================================
# MongoDB Configuration
# ============================================
# Credenciales para Docker MongoDB (docker-compose.yml)
ROOT_USERNAME=admin
ROOT_PASSWORD=admin123

# URI de conexión para la aplicación
# Para Docker: mongodb://admin:admin123@localhost:27017/
# Para MongoDB Atlas: mongodb+srv://user:password@cluster.mongodb.net/
MONGODB_URI=mongodb://localhost:27017/

# Nombre de la base de datos
MONGODB_DATABASE=pdf_extractext

# ============================================
# Application Configuration
# ============================================
# Nombre de la aplicación
APP_NAME=PDF Extractext

# Modo debug (True/False)
DEBUG=False

# Directorio para uploads temporales (no se usa con MongoDB)
UPLOAD_DIR=./uploads

# Tamaño máximo de archivo (10MB = 10 * 1024 * 1024)
MAX_FILE_SIZE=10485760
